#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
TG_SUPPORT_DATA_HOME="${TG_SUPPORT_HOME:-"$HOME/.tg-support"}"
VENV="${TG_SUPPORT_VENV:-"$TG_SUPPORT_DATA_HOME/.venv"}"
PYTHON="$VENV/bin/python"
BOOTSTRAP_MARKER="$VENV/.tg-support-bootstrap-v1"

if [ ! -x "$PYTHON" ]; then
  mkdir -p "$(dirname -- "$VENV")"
  python3 -m venv "$VENV"
fi

if [ ! -f "$BOOTSTRAP_MARKER" ]; then
  "$PYTHON" -m pip install --upgrade pip
  "$PYTHON" -m pip install -e "${ROOT}[telegram,render]"
  "$PYTHON" -m playwright install chromium
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "$BOOTSTRAP_MARKER"
fi

exec "$PYTHON" -m tg_support.cli "$@"
